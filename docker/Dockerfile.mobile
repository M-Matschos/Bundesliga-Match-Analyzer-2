# Build stage for Match Oracle Mobile App

FROM node:18-alpine

WORKDIR /app

# Install build tools
RUN apk add --no-cache \
    python3 \
    make \
    g++

# Copy package files
COPY mobile/package*.json ./

# Install dependencies
RUN npm ci

# Copy source code
COPY mobile ./

# Build the app
RUN npm run build

# Expose Expo Metro bundler port (development)
EXPOSE 8081

# Run development server
CMD ["npm", "start"]
