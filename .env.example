# Match Oracle — Environment Variables
# Kopiere diese Datei als .env und fülle die Werte aus

# Datenbank
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/match_oracle
REDIS_URL=redis://localhost:6379/0

# API Keys
API_FOOTBALL_KEY=your_rapidapi_key_here
FOOTBALL_DATA_KEY=your_football_data_key_here
ODDS_API_KEY=your_odds_api_key_here
OPENWEATHER_KEY=your_openweather_key_here

# Auth
JWT_SECRET=your_super_secret_key_change_this
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=168

# Tipico Affiliate
TIPICO_AFFILIATE_ID=your_tipico_affiliate_id

# App Settings
APP_ENV=development  # development / production
DEBUG=true
CORS_ORIGINS=http://localhost:3000,http://localhost:8081

# Docker Services (required when using docker-compose.yml)
POSTGRES_USER=bundesliga
POSTGRES_PASSWORD=change_me_in_production
REDIS_PASSWORD=change_me_in_production
