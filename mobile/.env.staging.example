# === Staging Environment Variables ===
# Use this configuration template for staging deployments
# HTTPS required for API Base URL in staging
# Do NOT commit real credentials

# === Environment Mode ===
REACT_APP_ENV=staging

# === Backend API Configuration ===
# Must use HTTPS in staging
REACT_APP_API_BASE_URL=https://staging-api.bundesliga-match-analyzer.local

# === Firebase Configuration (Staging Project) ===
# Use staging Firebase project credentials
REACT_APP_FIREBASE_API_KEY=staging_firebase_api_key_here
REACT_APP_FIREBASE_AUTH_DOMAIN=staging-project.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=staging_project_id
REACT_APP_FIREBASE_STORAGE_BUCKET=staging_project.appspot.com
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=staging_messaging_sender_id
REACT_APP_FIREBASE_APP_ID=staging_app_id

# === Feature Flags ===
REACT_APP_ENABLE_ANALYTICS=true
REACT_APP_ENABLE_PUSH_NOTIFICATIONS=true
REACT_APP_ENABLE_SENTRY=true

# === Debugging ===
REACT_APP_DEBUG_MODE=false
REACT_APP_LOG_LEVEL=info
