# ─── Datenbank ───────────────────────────────────────────────
DATABASE_URL=postgresql://matchoracle:password@localhost:5432/matchoracle
REDIS_URL=redis://localhost:6379/0

# ─── API Keys (alle notwendig!) ──────────────────────────────
# https://rapidapi.com/api-sports/api/api-football
API_FOOTBALL_KEY=DEIN_KEY_HIER

# https://www.football-data.org/client/register
FOOTBALL_DATA_KEY=DEIN_KEY_HIER

# https://openweathermap.org/api
OPENWEATHER_KEY=DEIN_KEY_HIER

# https://the-odds-api.com
ODDS_API_KEY=DEIN_KEY_HIER

# ─── Tipico Affiliate ────────────────────────────────────────
TIPICO_AFFILIATE_ID=DEINE_AFFILIATE_ID
TIPICO_AFFILIATE_SECRET=DEIN_SECRET

# ─── JWT Auth ────────────────────────────────────────────────
# Generieren: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=ZUFAELLIGER_LANGER_STRING_HIER_GENERIEREN
JWT_EXPIRE_MINUTES=10080   # 7 Tage

# ─── App Settings ────────────────────────────────────────────
DEBUG=True
ENVIRONMENT=development     # development | staging | production
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://localhost:8081

# ─── ML Settings ─────────────────────────────────────────────
MONTE_CARLO_SIMULATIONS=100000
ML_MODEL_PATH=backend/ml/training/models/xgboost_latest.json
AUTO_RETRAIN=True
RETRAIN_SCHEDULE=weekly     # daily | weekly

# ─── Cache TTL (Sekunden) ────────────────────────────────────
CACHE_PREDICTIONS_TTL=86400   # 24h
CACHE_FIXTURES_TTL=3600       # 1h
CACHE_ODDS_TTL=1800           # 30min
CACHE_WEATHER_TTL=10800       # 3h
