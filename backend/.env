# ─── Datenbank (SQLite für lokale Prototyping) ───────────────────────────────
DATABASE_URL=sqlite:///./test_seed.db
REDIS_URL=redis://localhost:6379/0

# ─── API Keys (Dummy für Development) ─────────────────────────────────────────
API_FOOTBALL_KEY=dummy_key_for_testing_12345
FOOTBALL_DATA_KEY=dummy_key_for_testing_12345
OPENWEATHER_KEY=dummy_key_for_testing_12345
ODDS_API_KEY=dummy_key_for_testing_12345

# ─── Tipico Affiliate (Optional) ──────────────────────────────────────────────
TIPICO_AFFILIATE_ID=dummy_id
TIPICO_AFFILIATE_SECRET=dummy_secret

# ─── JWT Auth ─────────────────────────────────────────────────────────────────
JWT_SECRET=super_secret_jwt_key_for_testing_change_in_production_12345678901234567890
JWT_EXPIRE_MINUTES=10080

# ─── App Settings ─────────────────────────────────────────────────────────────
DEBUG=True
ENVIRONMENT=development
LOG_LEVEL=DEBUG
CORS_ORIGINS=http://localhost:3000,http://localhost:8081,http://localhost:8000

# ─── ML Settings ──────────────────────────────────────────────────────────────
MONTE_CARLO_SIMULATIONS=10000
ML_MODEL_PATH=backend/ml/training/models/xgboost_latest.json
AUTO_RETRAIN=False
RETRAIN_SCHEDULE=weekly

# ─── Cache TTL (Sekunden) ──────────────────────────────────────────────────────
CACHE_PREDICTIONS_TTL=86400
CACHE_FIXTURES_TTL=3600
CACHE_ODDS_TTL=1800
CACHE_WEATHER_TTL=10800
